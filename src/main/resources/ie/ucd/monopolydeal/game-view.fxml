<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<BorderPane fx:id="rootPane"
            fx:controller="ie.ucd.monopolydeal.ui.GameController"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1180.0" prefHeight="760.0"
            style="-fx-padding: 12; -fx-background-color: #f1f5f9;">

    <top>
        <VBox spacing="8.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="Monopoly Deal FX" textFill="#0f172a">
                            <font>
                                <Font name="Segoe UI Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label fx:id="statusBadge" text="Ready" textFill="#4338ca" minWidth="-Infinity"
                               style="-fx-padding: 5 10 5 10; -fx-background-color: #e0e7ff; -fx-border-color: #a5b4fc; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <font>
                                <Font name="Segoe UI Semibold" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <GridPane hgap="12.0" maxWidth="1.7976931348623157E308">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" fillWidth="true" />
                        <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" fillWidth="true" />
                        <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" fillWidth="true" />
                        <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS" fillWidth="true" />
                    </columnConstraints>
                    <children>
                        <HBox GridPane.columnIndex="0" alignment="CENTER_LEFT" spacing="10.0" minHeight="58.0" prefHeight="58.0" maxHeight="58.0" maxWidth="1.7976931348623157E308"
                              style="-fx-padding: 8 10 8 10; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <children>
                                <Region prefWidth="5.0" minWidth="5.0" maxWidth="5.0" prefHeight="36.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 12;" />
                                <VBox spacing="2.0" minWidth="0.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="statusTitle" text="Status" textFill="#475569">
                                            <font>
                                                <Font name="Segoe UI Semibold" size="11.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="statusText" text="Start a new game." textFill="#0f172a" wrapText="true" minWidth="0.0" maxWidth="1.7976931348623157E308">
                                            <font>
                                                <Font name="Segoe UI Bold" size="16.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox GridPane.columnIndex="1" alignment="CENTER_LEFT" spacing="10.0" minHeight="58.0" prefHeight="58.0" maxHeight="58.0" maxWidth="1.7976931348623157E308"
                              style="-fx-padding: 8 10 8 10; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <children>
                                <Region prefWidth="5.0" minWidth="5.0" maxWidth="5.0" prefHeight="36.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 12;" />
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Turn" textFill="#475569">
                                            <font><Font name="Segoe UI Semibold" size="11.0" /></font>
                                        </Label>
                                        <Label fx:id="turnCount" text="0" textFill="#0f172a">
                                            <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox GridPane.columnIndex="2" alignment="CENTER_LEFT" spacing="10.0" minHeight="58.0" prefHeight="58.0" maxHeight="58.0" maxWidth="1.7976931348623157E308"
                              style="-fx-padding: 8 10 8 10; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <children>
                                <Region prefWidth="5.0" minWidth="5.0" maxWidth="5.0" prefHeight="36.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 12;" />
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Deck / Total" textFill="#475569">
                                            <font><Font name="Segoe UI Semibold" size="11.0" /></font>
                                        </Label>
                                        <Label fx:id="piles" text="0 / 0" textFill="#0f172a">
                                            <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox GridPane.columnIndex="3" alignment="CENTER_LEFT" spacing="10.0" minHeight="58.0" prefHeight="58.0" maxHeight="58.0" maxWidth="1.7976931348623157E308"
                              style="-fx-padding: 8 10 8 10; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <children>
                                <Region prefWidth="5.0" minWidth="5.0" maxWidth="5.0" prefHeight="36.0" style="-fx-background-color: #3b82f6; -fx-background-radius: 12;" />
                                <VBox spacing="2.0" minWidth="0.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Leading Player" textFill="#475569">
                                            <font><Font name="Segoe UI Semibold" size="11.0" /></font>
                                        </Label>
                                        <Label fx:id="leadingPlayer" text="-" textFill="#0f172a" wrapText="true" maxWidth="1.7976931348623157E308">
                                            <font><Font name="Segoe UI Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0" style="-fx-padding: 8 0 0 0;">
            <children>
                <VBox spacing="7.0" minWidth="0.0" maxWidth="1.7976931348623157E308" style="-fx-padding: 10; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 12; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Player Table" textFill="#0f172a">
                            <font><Font name="Segoe UI Bold" size="17.0" /></font>
                        </Label>
                        <Separator />
                        <ScrollPane fx:id="tableScroll" fitToWidth="false" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" pannable="true" VBox.vgrow="ALWAYS">
                            <content>
                                <HBox fx:id="tableBox" alignment="TOP_CENTER" spacing="12.0" fillHeight="true">
                                    <padding>
                                        <Insets top="8.0" right="10.0" bottom="10.0" left="10.0" />
                                    </padding>
                                </HBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox prefHeight="240.0" minHeight="218.0" maxHeight="270.0" spacing="7.0"
                      style="-fx-padding: 10; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 12; -fx-background-radius: 12;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="handCardsTitle" text="Current Hand" textFill="#0f172a">
                                    <font><Font name="Segoe UI Bold" size="17.0" /></font>
                                </Label>
                                <Label fx:id="actions" text="0 / 3" textFill="#1d4ed8"
                                       style="-fx-padding: 3 8 3 8; -fx-background-color: #dbeafe; -fx-border-color: #93c5fd; -fx-border-radius: 12; -fx-background-radius: 12;">
                                    <font><Font name="Segoe UI Semibold" size="12.0" /></font>
                                </Label>
                            </children>
                        </HBox>
                        <Separator />
                        <ScrollPane fx:id="cardsScroll" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" pannable="false" VBox.vgrow="ALWAYS">
                            <content>
                                <HBox fx:id="handCardsBox" alignment="CENTER" spacing="8.0" fillHeight="false">
                                    <padding>
                                        <Insets top="8.0" right="10.0" bottom="10.0" left="10.0" />
                                    </padding>
                                </HBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10 0 0 0;">
            <children>
                <Button fx:id="newGameButton" text="New Game" onAction="#onNewGame" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="moveWildButton" text="Move Wild" onAction="#onMoveWild" />
                <Button fx:id="playButton" text="Play Selected Card" onAction="#onPlaySelected" />
                <Button fx:id="endTurnButton" text="End Turn" onAction="#onEndTurn" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="usedCardsButton" text="Used Cards" onAction="#onUsedCards" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
